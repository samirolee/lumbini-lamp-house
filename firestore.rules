rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // {
    //   uid: string (required)
    //   email: string (required)
    //   role: string ('admin' | 'seeker')
    //   displayName: string
    // }
    //
    // Collection: media
    // {
    //   url: string (required)
    //   type: string ('image' | 'video')
    //   title: string
    //   caption: string
    //   createdAt: timestamp (required)
    //   uploadedBy: string (uid)
    // }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "samiroli2014@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'seeker'];
    }

    function isValidMedia(data) {
      return data.keys().hasAll(['url', 'type', 'createdAt']) &&
             data.url is string &&
             data.type in ['image', 'video'] &&
             data.createdAt is timestamp &&
             data.url.size() < 2048;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'seeker' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    isAdmin() && request.resource.data.uid == resource.data.uid;
    }

    match /media/{mediaId} {
      allow read: if true; // Public gallery
      allow create: if isAdmin() && isValidMedia(request.resource.data);
      allow update: if isAdmin() && isValidMedia(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
